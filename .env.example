PORT=3000

# Discord webhook เอาไว้แจ้งออเดอร์เข้าดิสคอร์ด
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/yyyyy

# เปิดใช้ตรวจสลิปจริง: true / false
ENABLE_SLIP_VERIFY=false

# ตัวอย่าง: เอาไว้ต่อ API ตรวจสลิป เช่น SlipOK หรือผู้ให้บริการที่ถูกต้อง
SLIP_VERIFY_API_URL=https://api.example.com/verify-slip
SLIP_VERIFY_API_KEY=put_your_api_key_here

# ชื่อบัญชี/เลขบัญชีร้าน เอาไว้เช็กว่าลูกค้าโอนเข้าบัญชีถูกไหม
SHOP_BANK_ACCOUNT_NAME=Your Shop Name
SHOP_BANK_ACCOUNT_NUMBER=0000000000
